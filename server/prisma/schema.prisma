generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

model User {
    id               String      @id @default(auto()) @map("_id") @db.ObjectId
    name             Boolean?
    email            String      @unique
    image            Boolean?
    bookedVisits     Json[]
    favResidenciesID String[]    @db.ObjectId
    ownedResidencies Residency[] @relation("Owner")
}

model Residency {
    id           String    @id @default(auto()) @map("_id") @db.ObjectId
    title        String
    description  String
    price        Int
    area         Int
    address      String
    city         String
    state        String
    country      String
    images       String[]
    facilities   Json
    ac           Boolean?
    heating      Boolean?
    wifi         Boolean?
    cable        Boolean?
    dryer        Boolean?
    washer       Boolean?
    laundry      Boolean?
    shower       Boolean?
    refrigerator Boolean?
    microwave    Boolean?
    pool         Boolean?
    gym          Boolean?
    type         Type?
    property     Property?
    userEmail    String
    owner        User      @relation("Owner", fields: [userEmail], references: [email])
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt

    @@unique(fields: [address, userEmail])
}

enum Type {
    buy
    rent
}

enum Property {
    apartment
    house
    condo
    land
}

